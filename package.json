{
  "name": "mcp-to-ai-sdk",
  "version": "0.1.0",
  "description": "CLI tool to generate Vercel AI SDK wrappers for MCP tools",
  "main": "dist/mcp-tools-cli.js",
  "bin": {
    "mcp-to-ai-sdk": "dist/mcp-tools-cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "dist/mcp-tools-cli.js",
    "sample": "tsx samples/grep-app-test.ts",
    "prepublishOnly": "npm run build",
    "test": "echo \"Error: no test specified\" && exit 1",
    "version-packages": "changeset version",
    "changeset": "changeset",
    "release": "pnpm build && changeset publish"
  },
  "keywords": [
    "mcp",
    "ai",
    "vercel",
    "ai-sdk",
    "cli",
    "tools",
    "model-context-protocol"
  ],
  "author": "Vercel",
  "files": [
    "dist/**/*"
  ],
  "license": "Apache-2.0",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.17.4",
    "ai": "^5.0.29",
    "commander": "^14.0.0",
    "json-schema-to-zod": "^2.6.1",
    "prettier": "^3.6.2",
    "zod": "^4.1.5"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.12",
    "@types/node": "^24.3.0",
    "dotenv": "^17.2.1",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2"
  },
  "publishConfig": {
    "access": "public"
  }
}
